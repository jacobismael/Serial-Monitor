<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:serial.Desktop"
        x:Class="serial.Desktop.MainWindow"
        x:DataType="local:MainWindow"
        Title="Logicom"
        Width="950"
        Height="600"
        MinWidth="1000"
        MinHeight="450"
        WindowStartupLocation="CenterScreen">

    <local:SessionControl x:Name="MainSessionControl" />
</Window>
