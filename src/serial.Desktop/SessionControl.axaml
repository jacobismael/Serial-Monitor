<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="serial.Desktop.SessionControl">
    <Grid Name="SessionRootGrid"
          Margin="24,26,24,24"
          RowDefinitions="Auto,Auto,*,Auto,Auto"
          RowSpacing="12"
          Background="#020403">
        <TextBlock Text="█   █▀█ █▀▀ █ █▀▀ █▀█ █▀▄▀█&#x0a;█▄▄ █▄█ █▄█ █ █▄▄ █▄█ █ ▀ █"
                   Grid.Row="0"
                   FontFamily="Menlo, Consolas, monospace"
                   Foreground="#F3F3F3"
                   FontSize="22"
                   FontWeight="Bold"
                   LineHeight="24" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,8,0,0">
            <TextBlock Text="Port:"
                       Foreground="#E8E8E8"
                       VerticalAlignment="Center" />

            <ComboBox Name="PortComboBox"
                      Width="260"
                      MinHeight="34" />

            <TextBlock Text="Baud:"
                       Foreground="#E8E8E8"
                       VerticalAlignment="Center" />

            <ComboBox Name="BaudComboBox"
                      Width="120"
                      MinHeight="34" />

            <TextBlock Text="Ending:"
                       Foreground="#E8E8E8"
                       VerticalAlignment="Center" />

            <ComboBox Name="LineEndingComboBox"
                      Width="128"
                      MinHeight="34" />

            <Button Name="RefreshButton"
                    Content="Refresh"
                    MinWidth="96" />

            <Button Name="ConnectButton"
                    Content="Connect"
                    MinWidth="120" />
        </StackPanel>

        <Grid Name="MainContentGrid"
              Grid.Row="2"
              ColumnDefinitions="*,340"
              ColumnSpacing="12">
            <Border Grid.Column="0"
                    BorderBrush="#9A9A9A"
                    BorderThickness="1"
                    Background="#020403"
                    CornerRadius="3">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Margin="12,8,12,4"
                               Text="SERIAL MONITOR -----------------------------------------------"
                               Foreground="#E8E8E8"
                               FontWeight="Bold" />
                    <ScrollViewer Name="OutputScrollViewer"
                                  Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <SelectableTextBlock Name="OutputTextBlock"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Stretch"
                                             FontSize="13"
                                             LineHeight="18"
                                             Foreground="#E8E8E8"
                                             TextWrapping="Wrap"
                                             Margin="12,4,12,12" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Name="StatusPanel"
                    Grid.Column="1"
                    BorderBrush="#9A9A9A"
                    BorderThickness="1"
                    Background="#020403"
                    CornerRadius="3"
                    Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBlock Name="StatusPanelTextBlock"
                               FontFamily="Menlo, Consolas, monospace"
                               FontSize="13"
                               LineHeight="18"
                               Foreground="#E8E8E8"
                               TextWrapping="NoWrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <WrapPanel Name="MacroButtonsPanel"
                   Grid.Row="3"
                   Orientation="Horizontal" />

        <Grid IsVisible="False">
            <GridSplitter Name="SignalViewerSplitter" />
            <Grid Name="SignalViewerPanel">
                <Grid Name="WaveformRowsGrid" />
                <ScrollViewer Name="WaveformScrollViewer" />
                <TextBlock Name="LogicAnalyzerHoverTextBlock" />
            </Grid>
        </Grid>

        <Grid Grid.Row="4"
              RowDefinitions="Auto,Auto"
              RowSpacing="4">
            <Border Name="MacroAutocompletePanel"
                    Grid.Row="0"
                    IsVisible="False"
                    BorderBrush="#9A9A9A"
                    BorderThickness="1"
                    Background="#020403"
                    CornerRadius="3"
                    Padding="6"
                    MaxHeight="180"
                    HorizontalAlignment="Left"
                    MinWidth="360">
                <ListBox Name="MacroAutocompleteListBox"
                         Background="#020403"
                         Foreground="#E8E8E8" />
            </Border>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="8">
                <TextBox Name="CommandTextBox"
                         Grid.Column="0"
                         MinHeight="36"
                         PlaceholderText="Type command..." />

                <Button Name="SendButton"
                        Grid.Column="1"
                        Content="Send"
                        Width="92"
                        IsEnabled="False" />

                <Button Name="ClearButton"
                        Grid.Column="2"
                        Content="Clear"
                        Width="92" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
