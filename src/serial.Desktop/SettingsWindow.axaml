<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="serial.Desktop.SettingsWindow"
        Title="Settings"
        Width="680"
        Height="420"
        MinWidth="520"
        MinHeight="320"
        CanResize="True"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20"
          RowDefinitions="*,Auto"
          RowSpacing="16">
        <TabControl Grid.Row="0">
            <TabItem Header="Appearance">
                <StackPanel Margin="0,12,0,0" Spacing="6">
                    <TextBlock Text="Font family" />
                    <TextBox Name="FontFamilyTextBox"
                             PlaceholderText="Monocraft, Menlo, Consolas, monospace" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Files">
                <StackPanel Margin="0,12,0,0" Spacing="6">
                    <TextBlock Text="Default log save location" />
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <TextBox Name="LogSaveLocationTextBox"
                                 Grid.Column="0"
                                 PlaceholderText="/Users/you/Documents" />
                        <Button Name="BrowseLogSaveLocationButton"
                                Grid.Column="1"
                                Content="Browse..."
                                Width="96" />
                    </Grid>
                </StackPanel>
            </TabItem>

            <TabItem Header="Macros">
                <ScrollViewer Margin="0,12,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnDefinitions="120,120,*"
                          RowSpacing="8"
                          ColumnSpacing="8">
                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Name" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   Text="Type" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Text="Command" />

                        <TextBox Name="Macro1NameTextBox"
                                 Grid.Row="1"
                                 Grid.Column="0"
                                 PlaceholderText="Reset" />
                        <ComboBox Name="Macro1TypeComboBox"
                                  Grid.Row="1"
                                  Grid.Column="1" />
                        <TextBox Name="Macro1CommandTextBox"
                                 Grid.Row="1"
                                 Grid.Column="2"
                                 PlaceholderText="reset or /path/to/tool --arg" />

                        <TextBox Name="Macro2NameTextBox"
                                 Grid.Row="2"
                                 Grid.Column="0" />
                        <ComboBox Name="Macro2TypeComboBox"
                                  Grid.Row="2"
                                  Grid.Column="1" />
                        <TextBox Name="Macro2CommandTextBox"
                                 Grid.Row="2"
                                 Grid.Column="2" />

                        <TextBox Name="Macro3NameTextBox"
                                 Grid.Row="3"
                                 Grid.Column="0" />
                        <ComboBox Name="Macro3TypeComboBox"
                                  Grid.Row="3"
                                  Grid.Column="1" />
                        <TextBox Name="Macro3CommandTextBox"
                                 Grid.Row="3"
                                 Grid.Column="2" />

                        <TextBox Name="Macro4NameTextBox"
                                 Grid.Row="4"
                                 Grid.Column="0" />
                        <ComboBox Name="Macro4TypeComboBox"
                                  Grid.Row="4"
                                  Grid.Column="1" />
                        <TextBox Name="Macro4CommandTextBox"
                                 Grid.Row="4"
                                 Grid.Column="2" />

                        <TextBox Name="Macro5NameTextBox"
                                 Grid.Row="5"
                                 Grid.Column="0" />
                        <ComboBox Name="Macro5TypeComboBox"
                                  Grid.Row="5"
                                  Grid.Column="1" />
                        <TextBox Name="Macro5CommandTextBox"
                                 Grid.Row="5"
                                 Grid.Column="2" />
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Name="CancelButton"
                    Content="Cancel"
                    Width="80" />
            <Button Name="ApplyButton"
                    Content="Apply"
                    Width="80" />
        </StackPanel>
    </Grid>
</Window>
