<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:serial.Desktop"
             x:Class="serial.Desktop.LogicAnalyzerControl">
    <Grid Name="AnalyzerRootGrid"
          Margin="24"
          ColumnDefinitions="*,340"
          ColumnSpacing="12"
          Background="#020403">
        <Grid IsVisible="False">
            <ComboBox Name="PortComboBox" />
            <ComboBox Name="BaudComboBox" />
            <Button Name="RefreshPortsButton" />
            <Button Name="ConnectButton" />
        </Grid>

        <Grid Grid.Column="0"
                  RowDefinitions="Auto,*,Auto"
                  RowSpacing="12">
            <Grid Grid.Row="0"
                  RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="8">
                <WrapPanel Grid.Row="0"
                           Orientation="Horizontal">
                    <Button Name="StartCaptureButton"
                            Content="Start Capture"
                            MinWidth="130"
                            Margin="0,0,8,8" />
                    <Button Name="StopCaptureButton"
                            Content="Stop Capture"
                            MinWidth="124"
                            IsEnabled="False"
                            Margin="0,0,8,8" />
                    <Button Name="SingleCaptureButton"
                            Content="Single Capture"
                            MinWidth="132"
                            Margin="0,0,8,8" />
                    <Button Name="StartAutoCaptureButton"
                            Content="Start Auto Capture"
                            MinWidth="164"
                            Margin="0,0,8,8" />
                    <Button Name="StopAutoCaptureButton"
                            Content="Stop Auto Capture"
                            MinWidth="158"
                            IsEnabled="False"
                            Margin="0,0,8,8" />
                    <Button Name="ClearCaptureButton"
                            Content="Clear"
                            MinWidth="82"
                            Margin="0,0,8,8" />
                    <Button Name="GenerateMockButton"
                            Content="Generate Mock Capture"
                            MinWidth="190"
                            Margin="0,0,8,8" />
                    <ComboBox Name="MockTypeComboBox"
                              Width="104"
                              MinHeight="34"
                              Margin="0,0,8,8" />
                    <Button Name="FitViewButton"
                            Content="Fit View"
                            MinWidth="92"
                            Margin="0,0,8,8" />
                    <Button Name="PreviousCaptureButton"
                            Content="Prev"
                            MinWidth="66"
                            Margin="0,0,8,8" />
                    <Button Name="NextCaptureButton"
                            Content="Next"
                            MinWidth="66"
                            Margin="0,0,8,8" />
                    <TextBlock Name="CaptureHistoryTextBlock"
                               Text="Capture 0 of 0"
                               VerticalAlignment="Center"
                               Margin="0,0,8,8" />
                </WrapPanel>

                <WrapPanel Grid.Row="1"
                           Orientation="Horizontal">
                    <TextBlock Text="Sample Rate:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,8" />
                    <NumericUpDown Name="SampleRateNumericUpDown"
                                   Width="128"
                                   Minimum="1"
                                   Maximum="100000000"
                                   Increment="1000"
                                   Value="1000000"
                                   Margin="0,0,8,8" />
                    <TextBlock Text="Hz"
                               VerticalAlignment="Center"
                               Margin="0,0,8,8" />
                    <TextBlock Text="Record Time:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,8" />
                    <NumericUpDown Name="RecordTimeNumericUpDown"
                                   Width="136"
                                   Minimum="0.001"
                                   Maximum="1000000"
                                   Increment="1"
                                   Value="10"
                                   Margin="0,0,8,8" />
                    <ComboBox Name="RecordTimeUnitComboBox"
                              Width="72"
                              MinHeight="34"
                              Margin="0,0,8,8" />
                    <TextBlock Text="Channels:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,8" />
                    <ComboBox Name="ChannelCountComboBox"
                              Width="84"
                              MinHeight="34"
                              Margin="0,0,8,8" />
                    <TextBlock Text="Trigger CH:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,8" />
                    <ComboBox Name="TriggerChannelComboBox"
                              Width="84"
                              MinHeight="34"
                              Margin="0,0,8,8" />
                    <TextBlock Text="Trigger:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,8" />
                    <ComboBox Name="TriggerModeComboBox"
                              Width="120"
                              MinHeight="34"
                              Margin="0,0,8,8" />
                    <TextBlock Text="Trigger Position:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,8" />
                    <NumericUpDown Name="TriggerPositionNumericUpDown"
                                   Width="92"
                                   Minimum="0"
                                   Maximum="100"
                                   Increment="5"
                                   Value="50"
                                   Margin="0,0,8,8" />
                    <TextBlock Text="%"
                               VerticalAlignment="Center"
                               Margin="0,0,8,8" />
                    <Button Name="ExportCsvButton"
                            Content="Export CSV"
                            MinWidth="110"
                            Margin="0,0,8,8" />
                    <Button Name="ExportVcdButton"
                            Content="Export VCD"
                            MinWidth="110"
                            Margin="0,0,8,8" />
                </WrapPanel>

                <Border Grid.Row="2"
                        BorderBrush="#5F5F5F"
                        BorderThickness="1"
                        Background="#020403"
                        CornerRadius="3"
                        Padding="10">
                    <Grid RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="8">
                        <WrapPanel Grid.Row="0"
                                   Orientation="Horizontal">
                            <TextBlock Text="TRIGGER BUILDER --------------------------------"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,8" />
                            <TextBlock Text="Mode:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,8" />
                            <ComboBox Name="TriggerBuilderModeComboBox"
                                      Width="110"
                                      MinHeight="34"
                                      Margin="0,0,8,8" />
                            <TextBlock Text="Combine:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,8" />
                            <ComboBox Name="TriggerCombineComboBox"
                                      Width="88"
                                      MinHeight="34"
                                      Margin="0,0,8,8" />
                            <Button Name="AddTriggerConditionButton"
                                    Content="Add Condition"
                                    MinWidth="128"
                                    Margin="0,0,8,8" />
                            <Button Name="ClearTriggerButton"
                                    Content="Clear Trigger"
                                    MinWidth="122"
                                    Margin="0,0,8,8" />
                            <Button Name="ApplyTriggerButton"
                                    Content="Apply Trigger"
                                    MinWidth="122"
                                    Margin="0,0,8,8" />
                        </WrapPanel>

                        <ScrollViewer Grid.Row="1"
                                      MaxHeight="118"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Name="TriggerConditionsPanel"
                                        Spacing="6" />
                        </ScrollViewer>

                        <WrapPanel Grid.Row="2"
                                   Orientation="Horizontal">
                            <TextBlock Text="Qualification:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,8" />
                            <ComboBox Name="QualificationModeComboBox"
                                      Width="206"
                                      MinHeight="34"
                                      Margin="0,0,8,8" />
                            <TextBox Name="QualificationConditionTextBox"
                                     Width="210"
                                     PlaceholderText="CH0 == 1"
                                     Margin="0,0,8,8" />
                            <TextBlock Text="Auto Limit:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,8" />
                            <ComboBox Name="AutoCaptureLimitComboBox"
                                      Width="104"
                                      MinHeight="34"
                                      Margin="0,0,8,8" />
                            <Button Name="CursorAButton"
                                    Content="Cursor A"
                                    MinWidth="86"
                                    Margin="0,0,8,8" />
                            <Button Name="CursorBButton"
                                    Content="Cursor B"
                                    MinWidth="86"
                                    Margin="0,0,8,8" />
                            <Button Name="ClearCursorsButton"
                                    Content="Clear Cursors"
                                    MinWidth="122"
                                    Margin="0,0,8,8" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Name="AnalyzerContentGrid"
                  Grid.Row="1"
                  RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        MinHeight="250"
                        BorderBrush="#9A9A9A"
                        BorderThickness="1"
                        Background="#020403"
                        CornerRadius="3"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0"
                                   Text="LOGIC ANALYZER -----------------------------------------------"
                                   FontWeight="Bold" />
                        <ScrollViewer Grid.Row="1"
                                      Margin="0,10,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <local:LogicWaveformView Name="WaveformView"
                                                     MinHeight="250"
                                                     HorizontalAlignment="Stretch" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <GridSplitter Name="ProtocolGridSplitter"
                              Grid.Row="1"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext" />

                <local:ProtocolAnalyzerControl Name="ProtocolAnalyzerPanel"
                                               Grid.Row="2"
                                               MinHeight="120" />
            </Grid>

            <Grid Grid.Row="2"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <TextBlock Name="StatusTextBlock"
                           Grid.Column="0"
                           Text="Disconnected."
                           Foreground="#E8E8E8" />
                <TextBlock Name="CursorTextBlock"
                           Grid.Column="1"
                           Text="Cursor: -"
                           Foreground="#9A9A9A" />
            </Grid>
        </Grid>

        <Border Name="ProbeStatusPanel"
                Grid.Column="1"
                BorderBrush="#9A9A9A"
                BorderThickness="1"
                Background="#020403"
                CornerRadius="3"
                Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock Name="ProbeFpgaStatusTextBlock"
                           FontFamily="Menlo, Consolas, monospace"
                           FontSize="13"
                           LineHeight="18"
                           Foreground="#E8E8E8"
                           TextWrapping="NoWrap" />
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
