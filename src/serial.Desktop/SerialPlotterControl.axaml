<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="serial.Desktop.SerialPlotterControl">
    <Grid Name="PlotterRootGrid"
          Margin="24"
          ColumnDefinitions="*,340"
          ColumnSpacing="12"
          Background="#020403">
        <Grid Grid.Column="0"
              RowDefinitions="Auto,*"
              RowSpacing="12">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                  ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Text="SERIAL PLOTTER -----------------------------------------------"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
                <Button Name="PauseResumeButton"
                        Grid.Column="1"
                        Content="Pause"
                        MinWidth="82" />
                <Button Name="AutoYButton"
                        Grid.Column="2"
                        Content="Auto Y"
                        MinWidth="82" />
                <Button Name="FitViewButton"
                        Grid.Column="3"
                        Content="Fit View"
                        MinWidth="86" />
                <Button Name="ResetZoomButton"
                        Grid.Column="4"
                        Content="Reset Zoom"
                        MinWidth="104" />
                <ComboBox Name="XAxisModeComboBox"
                          Grid.Column="5"
                          Width="104"
                          MinHeight="34" />
                <Button Name="ExportVisibleButton"
                        Grid.Column="6"
                        Content="Export Visible CSV"
                        MinWidth="150" />
                <Button Name="ExportFullButton"
                        Grid.Column="7"
                        Content="Export Full CSV"
                        MinWidth="132" />
                <Button Name="ClearPlotButton"
                        Grid.Column="8"
                        Content="Clear Plot"
                        MinWidth="100" />
                <Button Name="ClearHistoryButton"
                        Grid.Column="9"
                        Content="Clear History"
                        MinWidth="118" />
            </Grid>

            <Border Grid.Row="1"
                    BorderBrush="#9A9A9A"
                    BorderThickness="1"
                    Background="#020403"
                    CornerRadius="3"
                    Padding="12">
                <Canvas Name="PlotCanvas"
                        MinHeight="260"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" />
            </Border>
        </Grid>

        <Border Name="PlotterStatusPanel"
                Grid.Column="1"
                BorderBrush="#9A9A9A"
                BorderThickness="1"
                Background="#020403"
                CornerRadius="3"
                Padding="12">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="STATUS --------------------------------"
                           FontWeight="Bold" />
                <ScrollViewer Grid.Row="1"
                              Margin="0,10,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBlock Name="PlotterStatusTextBlock"
                               FontFamily="Menlo, Consolas, monospace"
                               FontSize="13"
                               LineHeight="18"
                               Foreground="#E8E8E8"
                               TextWrapping="NoWrap" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
